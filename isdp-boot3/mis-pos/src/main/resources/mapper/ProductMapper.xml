<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.scau.mis.pos.mapper.IProductMapper">

    <resultMap type="edu.scau.mis.pos.domain.Product" id="productResultMap">
        <id property="productId" column="product_id"/>
        <result property="productSn" column="product_sn"/>
        <result property="productName" column="product_name"/>
        <result property="productDescription" column="product_description"/>
        <result property="price" column="price"/>
        <result property="productCategoryId" column="product_category_id"/>
        <result property="imageUrl" column="image_url"/>
        <result property="detailUrl" column="detail_url"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <association property="category" javaType="edu.scau.mis.pos.domain.Category">
            <id property="categoryId" column="category_id"/>
            <result property="parentId" column="parent_id"/>
            <result property="categoryName" column="category_name"/>
        </association>
    </resultMap>

    <!-- 定义SQL片段，用于复用查询字段 -->
    <sql id="selectProductVo">
        SELECT
            p.product_id,
            p.product_sn,
            p.product_name,
            p.product_description,
            p.price,
            p.product_category_id,
            p.image_url,
            p.detail_url,
            p.create_by,
            p.create_time,
            p.update_by,
            p.update_time,
            c.category_id as category_id,
            c.parent_id as parent_id,
            c.category_name as category_name
        FROM pos_product p LEFT JOIN pos_category c
                                     ON p.product_category_id = c.category_id
    </sql>

    <!-- 根据ID查询单个商品 -->
    <select id="selectProductById" parameterType="Long" resultMap="productResultMap">
        <include refid="selectProductVo"/>
        WHERE p.product_id = #{productId}
    </select>

    <!-- 根据商品编码查询商品 -->
    <select id="selectProductBySn" parameterType="String" resultMap="productResultMap">
        <include refid="selectProductVo"/>
        WHERE p.product_sn = #{productSn}
    </select>

    <!-- 查询产品列表（带参数） -->
    <select id="selectProductList" parameterType="edu.scau.mis.pos.domain.Product" resultMap="productResultMap">
        <include refid="selectProductVo"/>
        <where>
            <if test="productSn != null and productSn != ''">
                AND p.product_sn = #{productSn}
            </if>
            <if test="productName != null and productName != ''">
                AND p.product_name LIKE CONCAT('%', #{productName}, '%')
            </if>
            <if test="productCategoryId != null and productCategoryId != 0">
                AND p.product_category_id = #{productCategoryId}
            </if>
        </where>
        ORDER BY p.product_id ASC
    </select>

    <!-- 查询所有商品列表 -->
    <select id="selectAllProductList" resultMap="productResultMap">
        <include refid="selectProductVo"/>
        ORDER BY p.product_id ASC
    </select>

    <insert id="insertProduct" parameterType="edu.scau.mis.pos.domain.Product" useGeneratedKeys="true" keyProperty="productId">
        INSERT INTO pos_product (
            product_sn, product_name, product_description, price,
            product_category_id, image_url, detail_url, create_by, create_time
        ) VALUES (
                     #{productSn}, #{productName}, #{productDescription}, #{price},
                     #{productCategoryId}, #{imageUrl}, #{detailUrl}, #{createBy}, #{createTime}
                 )
    </insert>

    <update id="updateProduct" parameterType="edu.scau.mis.pos.domain.Product">
        UPDATE pos_product
        SET
            product_sn = #{productSn},
            product_name = #{productName},
            product_description = #{productDescription},
            price = #{price},
            product_category_id = #{productCategoryId},
            image_url = #{imageUrl},
            detail_url = #{detailUrl},
            update_by = #{updateBy},
            update_time = #{updateTime}
        WHERE product_id = #{productId}
    </update>

    <delete id="deleteProductById" parameterType="Long">
        DELETE FROM pos_product WHERE product_id = #{productId}
    </delete>

    <!-- 批量删除方法 -->
    <delete id="deleteProductByIds" parameterType="Long">
        DELETE FROM pos_product WHERE product_id IN
        <foreach collection="array" item="productId" open="(" separator="," close=")">
            #{productId}
        </foreach>
    </delete>

</mapper>