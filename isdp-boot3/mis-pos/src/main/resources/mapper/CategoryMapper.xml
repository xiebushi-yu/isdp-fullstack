<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.scau.mis.pos.mapper.ICategoryMapper">

    <resultMap type="edu.scau.mis.pos.domain.Category" id="categoryResultMap">
        <id property="categoryId" column="category_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="categoryName" column="category_name"/>
        <!-- 继承自 BaseEntity 的字段 -->
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!-- 定义SQL片段，用于复用查询字段 -->
    <sql id="selectCategoryVo">
        SELECT
            category_id,
            parent_id,
            category_name,
            create_by,
            create_time,
            update_by,
            update_time
        FROM pos_category
    </sql>

    <!-- 根据ID查询分类 -->
    <select id="selectCategoryById" parameterType="Long" resultMap="categoryResultMap">
        <include refid="selectCategoryVo"/>
        WHERE category_id = #{categoryId}
    </select>

    <!-- 根据父级ID查询分类列表 -->
    <select id="selectCategoryByParentId" parameterType="Long" resultMap="categoryResultMap">
        <include refid="selectCategoryVo"/>
        WHERE parent_id = #{parentId}
    </select>

    <!-- 查询所有分类列表 -->
    <select id="selectAllCategoryList" resultMap="categoryResultMap">
        <include refid="selectCategoryVo"/>
        ORDER BY category_id ASC
    </select>

    <!-- 新增分类 -->
    <insert id="insertCategory" parameterType="edu.scau.mis.pos.domain.Category" useGeneratedKeys="true" keyProperty="categoryId">
        INSERT INTO pos_category (
            parent_id,
            category_name,
            create_by,
            create_time
        ) VALUES (
                     #{parentId},
                     #{categoryName},
                     #{createBy},
                     #{createTime}
                 )
    </insert>

    <!-- 修改分类 -->
    <update id="updateCategory" parameterType="edu.scau.mis.pos.domain.Category">
        UPDATE pos_category
        SET
            parent_id = #{parentId},
            category_name = #{categoryName},
            update_by = #{updateBy},
            update_time = #{updateTime}
        WHERE category_id = #{categoryId}
    </update>

    <!-- 删除分类 -->
    <delete id="deleteCategoryById" parameterType="Long">
        DELETE FROM pos_category WHERE category_id = #{categoryId}
    </delete>

    <!-- 批量删除分类 -->
    <delete id="deleteCategoryByIds" parameterType="Long">
        DELETE FROM pos_category WHERE category_id IN
        <foreach collection="array" item="categoryId" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>

</mapper>